# Shared runtime configuration for Docker deployment.
# Service-to-service addresses are injected by docker-compose.yml.

SECRET_KEY=replace-with-a-strong-random-secret

LANSHARE_DATA_ROOT=/app/data

# Database backend. Keep sqlite until the PostgreSQL migration gates pass.
# Do not set DB_ENGINE=postgres on production before a verified backup,
# migration report, postflight checks, and rollback plan exist.
DB_ENGINE=sqlite
DATABASE_URL=
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=4
POSTGRES_STATEMENT_TIMEOUT_MS=30000
POSTGRES_LOCK_TIMEOUT_MS=5000
POSTGRES_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000
POSTGRES_BACKEND_READY=false

# Optional Docker Compose PostgreSQL overlay.
# Keep POSTGRES_PASSWORD empty in the template; set it only in the real remote
# docker.env or a local untracked lab env file. Never commit production secrets.
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lanshare
POSTGRES_USER=lanshare
POSTGRES_PASSWORD=
POSTGRES_HOST_DATA_DIR=./data/postgres

# Runtime timezone used by Python, SQLite localtime expressions, and container logs.
TZ=Asia/Shanghai
APP_TIMEZONE=Asia/Shanghai

TEACHER_NAME=teacher
TEACHER_PASSWD=admin123

TOTAL_UPLOAD_MBPS=100.0
MAX_UPLOAD_SIZE_MB=2048
MAX_HISTORY_IN_MEMORY=500
STUDENT_HISTORY_COUNT=200
TEACHER_HISTORY_COUNT=500
MAX_SUBMISSION_FILE_COUNT=500

# SQLite / behavior-tracking concurrency tuning.
SQLITE_BUSY_TIMEOUT_MS=30000
SQLITE_CACHE_SIZE_KB=8192
SQLITE_WAL_AUTOCHECKPOINT_PAGES=2000
BEHAVIOR_WRITE_QUEUE_SIZE=20000
BEHAVIOR_WRITE_BATCH_SIZE=128
BEHAVIOR_WRITE_FLUSH_INTERVAL_MS=250
EXAM_GENERATION_STALE_MINUTES=180
AI_GRADING_STALE_MINUTES=240

# Limit classroom shared-file/material downloads on low-bandwidth cloud servers.
# Set CLASSROOM_DOWNLOAD_LIMIT_ENABLED=false to disable the restriction.
# CLASSROOM_DOWNLOAD_MAX_SIZE supports values like 0, 512MB, 1GB.
CLASSROOM_DOWNLOAD_LIMIT_ENABLED=false
CLASSROOM_DOWNLOAD_MAX_SIZE=0

# Public URL used in outgoing email action links.
PUBLIC_SITE_BASE_URL=https://www.guardianangel.net.cn

# Email outbox worker tuning. Mail is queued by the main app and sent by the separate mailer service.
EMAIL_WORKER_POLL_SECONDS=5
EMAIL_WORKER_BATCH_SIZE=20
EMAIL_WORKER_MAX_ATTEMPTS=5
EMAIL_SMTP_TIMEOUT_SECONDS=12
EMAIL_IMAP_TIMEOUT_SECONDS=12
EMAIL_DEFAULT_PER_MINUTE_LIMIT=25
EMAIL_DEFAULT_DAILY_LIMIT=300
EMAIL_WORKER_HEARTBEAT_TIMEOUT_SECONDS=90

# AI blog news crawler worker. Detailed schedule and limits can also be changed
# from Manage Center -> System -> AI blog housekeeper.
BLOG_NEWS_CRAWLER_WORKER_ID=blog-crawler-compose
BLOG_NEWS_CRAWLER_POLL_SECONDS=60
BLOG_NEWS_CRAWLER_USER_AGENT=Mozilla/5.0 (compatible; LanShareAIBlogCrawler/1.0; course-news-curator)

# Public site record shown at the bottom of the unauthenticated entry pages.
SITE_DISPLAY_NAME=课堂互动平台
SITE_OWNER_NAME=张老师
SITE_OWNER_STATEMENT=本网站（课堂互动平台）由张老师负责运营，站内内容与服务均归权利人依法所有。
SITE_ICP_RECORD_NUMBER=桂ICP备2026007021号
SITE_ICP_RECORD_APPROVED_AT=2026-04-20
SITE_ICP_RECORD_LOOKUP_URL=https://beian.miit.gov.cn
SITE_ICP_NOTICE_SOURCE=工信部ICP备案

# Prefer GLOBAL_AI_CONCURRENCY. AI_WORKER_CONCURRENCY is still accepted for backward compatibility.
GLOBAL_AI_CONCURRENCY=8
AI_QUEUE_MAX_PENDING=200
AI_PROVIDER_QUEUE_MAX_PENDING=200
AI_GRADING_MAX_CONCURRENT_JOBS=4
AI_GRADING_MAX_PENDING_JOBS=200
AI_GRADING_CALLBACK_MAX_ATTEMPTS=4
AI_GRADING_CALLBACK_RETRY_BASE_SECONDS=2
AI_PROVIDER_HTTP_MAX_ATTEMPTS=4
AI_PROVIDER_HTTP_RETRY_BASE_SECONDS=8
AI_PROVIDER_HTTP_RETRY_MAX_SECONDS=90
AI_PLATFORM_PRIORITY=deepseek,volcengine
AI_TEXT_SPILLOVER_ENABLED=true
# Non-streaming app endpoints still ask providers for streaming chunks and collect them server-side.
AI_NONSTREAM_USE_PROVIDER_STREAM=true
# Text tasks stay on DeepSeek until this many in-flight text requests are already reserved.
DEEPSEEK_TEXT_SPILLOVER_THRESHOLD=8
AI_USAGE_LOG_ENABLED=true
AI_USAGE_LOG_TO_STDOUT=true
AI_USAGE_LOG_PATH=logs/ai_usage.jsonl

# Teacher Agent Task Center. The worker is separate from the main web service
# and talks to the isolated deepseek-runtime container over the internal network.
AGENT_TASKS_ENABLED=true
AGENT_TASK_RUNTIME_URL=http://deepseek-runtime:7878
AGENT_TASK_RUNTIME_TOKEN=replace-with-agent-runtime-token
# Keep this equal to AGENT_TASK_RUNTIME_TOKEN for the DeepSeek-TUI HTTP server.
DEEPSEEK_RUNTIME_TOKEN=replace-with-agent-runtime-token
AGENT_TASK_RUNTIME_MODEL=deepseek-v4-pro
AGENT_TASK_RUNTIME_WORKSPACE_PREFIX=/workspace/tasks
AGENT_TASK_GLOBAL_CONCURRENCY=2
AGENT_TASK_WORKER_CONCURRENCY=2
AGENT_TASK_WORKER_ID=agent-worker-compose
AGENT_TASK_WORKER_POLL_SECONDS=5
AGENT_TASK_RUNTIME_POLL_SECONDS=5
AGENT_TASK_MAX_RUNTIME_SECONDS=1800
AGENT_TASK_DEEPSEEK_AUTO_APPROVE=false
AGENT_TASK_ALLOW_RUNTIME_SHELL=false
DEEPSEEK_TUI_WORKERS=2
DEEPSEEK_TUI_TAG=latest
# Bootstrap fallback for deepseek-runtime. Super admins can later manage and
# test Agent keys in /manage/system/agent-keys; the active key is written to
# ./data/agent_tasks/deepseek_home/config.toml and takes effect after restarting
# the deepseek-runtime service.
DEEPSEEK_API_KEY=

DEEPSEEK_ENABLED=false
DEEPSEEK_MODEL_STANDARD=deepseek-v4-flash
DEEPSEEK_MODEL_THINKING=deepseek-v4-pro
DEEPSEEK_MODEL_FAST_TEXT=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP_TEXT=deepseek-v4-pro
# DeepSeek publishes dynamic concurrency control rather than a fixed per-key cap; tune this from 429/latency telemetry.
DEEPSEEK_MAX_CONCURRENT_REQUESTS=8

SILICONFLOW_ENABLED=False
SILICONFLOW_API_KEY=
SILICONFLOW_MAX_CONCURRENT_REQUESTS=0

VOLCENGINE_ENABLED=false
ARK_API_KEY=
VOLCENGINE_OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL_STANDARD=doubao-seed-2-0-lite-260428
VOLCENGINE_MODEL_THINKING=doubao-seed-2-0-pro-260215
VOLCENGINE_MODEL_VISION=doubao-seed-2-0-pro-260215
VOLCENGINE_MODEL_TEXT_FAST=doubao-seed-2-0-lite-260428
VOLCENGINE_MODEL_TEXT_DEEP=doubao-seed-2-0-pro-260215
VOLCENGINE_MODEL_MULTIMODAL_LIGHT=doubao-seed-2-0-lite-260428
VOLCENGINE_MODEL_MULTIMODAL_DEEP=doubao-seed-2-0-pro-260215
# Set this to the real Ark endpoint/model concurrency or TPM capacity purchased in Volcengine console.
VOLCENGINE_MAX_CONCURRENT_REQUESTS=4
