# --- 课堂服务器配置 (main.py) ---
MAIN_HOST=0.0.0.0
MAIN_PORT=8000
# 关键修改: ai 服务将通过 'app' (compose中的服务名) 访问主服务
MAIN_APP_CALLBACK_URL=http://app:8000/api/internal/grading-complete

# --- AI 助手服务器配置 (ai_assistant.py) ---
# 关键修改: 必须绑定到 0.0.0.0 才能从其他容器访问
AI_HOST=0.0.0.0
AI_PORT=8001
AI_WORKER_CONCURRENCY=3

# 新增: 主应用需要知道 AI 助手的地址
# 'ai' 是 docker-compose.yml 中定义的服务名
AI_ASSISTANT_URL=http://ai:8001

# --- AI 平台启用与优先级 (保持不变) ---
AI_PLATFORM_PRIORITY=volcengine,deepseek,siliconflow
DEEPSEEK_ENABLED=True
DEEPSEEK_API_KEY=sk-9ee67b824cec4050b56d31a4f38d526e
DEEPSEEK_MODEL_STANDARD=deepseek-chat
DEEPSEEK_MODEL_THINKING=deepseek-reasoner

SILICONFLOW_ENABLED=True
SILICONFLOW_API_KEY=sk-efrcbwroabofphyspnvtosjgtyyxuauoqfzrdkijiyzcglyd
SILICONFLOW_MODEL_STANDARD=Pro/deepseek-ai/DeepSeek-V3
SILICONFLOW_MODEL_THINKING=Pro/deepseek-ai/DeepSeek-V3.2-Exp
SILICONFLOW_MODEL_VISION=Qwen/Qwen3-VL-235B-A22B-Thinking

